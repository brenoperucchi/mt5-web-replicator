                          = link_to contract_dashboard_path(trace), class: 'btn btn-primary w-100' do
                            = I18n.t :contract, scope:'helpers.dashboards'
      / .row
        .col-12
          - @traces.reverse.each do |amount_profit, id|                   
            - trace = Trace.find(id)
            - next if params[:kind] != 'all' and trace.capital_recomendation.nil?
            - trace.search_date_begin      = session[:date_begin].strip().to_datetime.change(offset: @timezone)
            - trace.search_date_end        = session[:date_end].strip().to_datetime.change(offset: @timezone)            
            .card
              = link_to dashboard_path(trace, params:request.query_parameters) do
                .card-body
                  .row.pb-4
                    .col-lg-4.d-flex.align-items-stretch
                      .d-flex.flex-column.align-items-start.w-100
                        .text-start
                          h5.card-title.fw-semibold
                            = trace.name
                          span
                            = "#{I18n.l trace.search_date_begin, format: :short2} - #{I18n.l trace.search_date_end, format: :short2}"
                        .mt-lg-auto.mt-4.mb-4
                          span.text-dark
                            | Total Revenue 
                            span.text-success
                              |  9.78%
                          h2.mt-2.fw-bold
                            = number_with_precision amount_profit, precision:2
                          span
                            | Increased 15% from last month
                    .col-lg-8.d-flex.align-items-stretch
                      .w-100
                        .mt-4
                          #financial
                .border-top
                  .row.gx-0
                    .col-md-4.border-end
                      .p-4.py-3.py-md-4
                        p.fs-4.text-danger.mb-0
                          span.text-danger
                            span.round-8.bg-danger.rounded-circle.d-inline-block.me-1
                          = I18n.t :profit_trade, scope:'helpers.dashboards.pages.show'
                        h3.mt-2.mb-0
                          = "#{trace.profit_trade(:masters)} %"
                    .col-md-4.border-end
                      .p-4.py-3.py-md-4
                        p.fs-4.text-primary.mb-0
                          span.text-primary
                            span.round-8.bg-primary.rounded-circle.d-inline-block.me-1
                          = I18n.t :profit_factor, scope:'helpers.dashboards.pages.show'
                        h3.mt-2.mb-0
                          = number_with_precision trace.profit_factor(:masters).round(2), precision:2
                    .col-md-4
