#main-wrapper.page-wrapper[data-layout="vertical" data-sidebartype="full" data-navbarbg="skin6" data-sidebar-position="fixed" data-header-position="fixed"]
  <!-- Sidebar Start -->
  / = render "layouts/modernize/sidebar"
  .body-wrapper
    <!-- Header Start -->
    / = render "layouts/modernize/header"

    .container-fluid
      .row
        - @traces.reverse.each do |amount_profit, id|                   
          - trace = Trace.find(id)
          - next if params[:kind] != 'all' and trace.capital_recomendation.nil?
          - trace.search_date_begin      = session[:date_begin].strip().to_datetime.change(offset: @timezone)
          - trace.search_date_end        = session[:date_end].strip().to_datetime.change(offset: @timezone)       
          .col-lg-8.d-flex.align-items-strech
              .card.w-100
                .card-body
                  = link_to dashboard_path(trace, params:request.query_parameters) do
                    .d-sm-flex.d-block.align-items-center.justify-content-between.mb-9
                      .mb-3.mb-sm-0
                        h5.card-title.fw-semibold
                          = trace.name
                        p.card-subtitle.mb-0
                          | Overview of Profit
                      div
                        select.form-select
                          option[value="1"]
                            | March 2023
                          option[value="2"]
                            | April 2023
                          option[value="3"]
                            | May 2023
                          option[value="4"]
                            | June 2023
                  .row.align-items-center
                    .col-lg-8.col-md-8
