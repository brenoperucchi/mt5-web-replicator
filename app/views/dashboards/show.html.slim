  .row
    .col-md-12
      .card.table-card.latest-activity-card
        .card-header
          h5 Accounts
        .card-body
          .table-responsive
            table.table.table-hover.table-borderless#accounts
              thead
                tr
                  th Account
                  th 
                  th Fator Lucro
                  th Tx de Acerto
                  th Lucro/MaxDD
                  th 
                  th Op Open 
                  th Op Closes 
                  th Op Error
                  th 
                  th Qtd Total
                  th $ Total
              tbody
                - @accounts.each do |account|
                  - account.search_date_begin = session[:date_begin].strip().to_datetime.change(offset: @timezone)
                  - account.search_date_end = session[:date_end].strip().to_datetime.change(offset: @timezone)
                  tr[data-href="#{account_dashboard_path(@current_store.url, @trace.name, account.id, datefilter:params[:datefilter])}"]
                    - if account.slave?
                      - type = :slaves
                      - @data_scope_executed_closed = account.data_scope(type, [:executed, :closed], nil, @trace)
                    - else
                      - type = :transactions
                      - @data_scope_executed_closed = account.data_scope(type, [:executed, :closed], nil, @trace)&.not_limit_pending
                    td = "#{account.name} - #{account.kind}"
                    td
                    td = number_with_precision account.profit_factor(type, @trace).round(2), precision: 2
                    td = account.profit_trade(type, @trace)
                    td = number_with_precision account.profit_drawdown(type, @trace), precision: 2
                    td 
                    td = number_with_precision account.data_scope(type, :executed, nil, @trace).to_a.sum(&:profit), precision: 2
                    td = number_with_precision account.data_scope(type, :closed, nil, @trace).to_a.sum(&:profit), precision: 2
                    td = number_with_precision account.data_scope(type, :error, nil, @trace).to_a.sum(&:profit), precision: 2
                    td 
                    td = @data_scope_executed_closed.count
                    td = number_with_precision @data_scope_executed_closed.to_a.sum(&:profit), precision: 2       

