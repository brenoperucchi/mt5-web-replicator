- chart_values =  @trace.dashboard_capital_accumulated(true)
- chart_regression = AlgoStatistic.trend_line(chart_values)
- chart_regression = [chart_regression[0], chart_regression[-1]]
- content_for :header do
  css:
    /* CSS para o contêiner flexível */
    .flex-container {
        display: flex;
        flex-wrap: wrap; /* Permite que os itens se ajustem em várias linhas, se necessário */
    }

    .flex-container .col-sm-8, .flex-container .col-md-6 {
        display: flex;
        flex-direction: column;
    }

    .flex-container .card {
        flex-grow: 1; /* Faz com que cada card expanda para preencher o espaço disponível */
        width: 100%; /* Garante que o card ocupe toda a largura da coluna */
    }
    .card-body {
        display: flex;
        flex-direction: column;
        justify-content: space-between; /* Distribui o espaço uniformemente */
        height: 100%; /* Faz com que a .card-body ocupe toda a altura da .card */
    }

- content_for :breadcrumb do
