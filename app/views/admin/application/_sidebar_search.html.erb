<nav id="sidebar" class="order-last active">
  <div class="custom-menu">
    <button type="button" id="sidebarCollapse" class="btn btn-primary">
    </button>
  </div>
  <div class="search">
    <% 
      namespace = local_assigns[:namespace] || :admin 
      attribute_types = {
      symbol: Administrate::Field::String,
      profit_search: Administrate::Field::String,
      account_id: Administrate::Field::Select.with_options(collection: Account.account_search(current_user)), 
      state: Administrate::Field::Select.with_options(collection: states)
    } %>

    <% if defined?(attribute_types_custom) %>
      <% attribute_types = attribute_types_custom.merge(attribute_types.merge) %>
    <% end %>
    <%= render('administrate_ransack/filters', attribute_labels: attribute_labels, attribute_types: attribute_types, options: { tags: 'select' }, namespace: namespace ) %>
  </div>
</nav>