                  | Work Email
                  small.text-danger *
                input#demo_email.form-control placeholder="john@doe.com" required="" type="email" /
              .mb-3
                label.form-label for="demo_job_title" 
                  | Job
                  '
                  | Title
                input#demo_job_title.form-control placeholder=("React Developer") type="text" /
              .mb-3
                label.form-label Team size
                select#teamSize.form-select name="teamSize" 
                  option value="0-10"  0-10
                  option value="10-25"  10-25
                  option value="25-50"  25-50
                  option value="50+"  50+
              .d-grid.mb-3
                button.btn.btn-primary type="submit" 
                  | Submit
                  '
                  | Request
