              .mb-3
                label.form-label for="demo_f_name" 
                  | First
                  '
                  | Name
                input#demo_f_name.form-control placeholder="John" type="text" /
              .mb-3
                label.form-label for="demo_l_name" 
                  | Last
                  '
                  | Name
                input#demo_l_name.form-control placeholder="Doe" type="text" /
              .mb-3
