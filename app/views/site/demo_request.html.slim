          li.d-flex.mb-3.align-items-start
            span.material-symbols-rounded.align-middle.text-warning.fs-4.me-3> check_circle
            = I18n.t :rules2, scope: 'helpers.site.signup_demo'
          li.d-flex.mb-3.align-items-start
            span.material-symbols-rounded.align-middle.text-warning.fs-4.me-3> check_circle
            = I18n.t :rules3, scope: 'helpers.site.signup_demo'



        .card.border-0.rounded-4.shadow-lg.py-5.px-4
