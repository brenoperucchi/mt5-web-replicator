
<% if field.options[:type] == "has_many" %>
	
	<% if field.options[:scope].nil? %>
		<%= field.resource.send(field.options[:association]).map(&:name).join(', ') %>
	<% else %>
		<%= field.resource.send(field.options[:association]).try(field.options[:association]).map(&:name).join(', ') %>
	<% end %>

<% else %>

	<%= field.data.name %>

<% end %>
