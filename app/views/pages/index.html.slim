- @traces.each do |trace|                   
  .flex.flex-col.col-span-full.sm:col-span-6.xl:col-span-4.bg-white.shadow-lg.rounded-sm.border.border-slate-200
    header.px-5.py-4.border-b.border-slate-100
      h2.font-semibold.text-slate-800 = trace.name
    /! Card content
    .flex.flex-col.h-full
      /! Live visitors number
      / .px-5.py-1
      /   .flex.items-center
      /     div
      /       .text-sm.text-slate-800.pt-1      
      /         = "Compra #{trace.transactions.executed.buy.count}"
      / .px-5.py-1
      /   .flex.items-center
      /     div
      /       .text-sm.text-slate-800.pt-1      
      /         = "Venda #{trace.transactions.executed.sell.count}"

      /! Chart built with Chart.js 3
      /! Check out src/js/components/analytics-card-02.js for config
        / div
        /   /! Change the height attribute to adjust the chart height
        /   canvas#analytics-card-02 height="70" width="389" 
      /! Table
      .grow.px-5.pt-2.pb-2
        .overflow-x-auto
          table.table-auto.w-full
            /! Table header
            thead.text-xs.text-slate-800
              tr
                th.text-xl.text-slate-800.text-left Master
                th.text-xl.text-slate-800.text-right Slaves
            /! Table body
            tbody.text-sm.divide-y.divide-slate-100
              /! Row
              tr
                td.text-2xl.font-bold.text-blue-500
                  = "R$ #{trace.masters.closed.sum(:profit)}"
                  .text-sm.text-slate-800.pt-1 = "Closed Operations #{trace.masters.closed.count}"
                td.text-2xl.font-bold.text-blue-500.text-right
                  = "R$ #{trace.slaves.closed.sum(:profit)}"
                  .text-sm.text-slate-800.pt-1 = "Closed Operations #{trace.slaves.closed.count}"
              tr
                td.text-2xl.font-bold.text-blue-500
                  = "#{trace.profit_trade(:masters).round(2)} %"
                  .text-sm.text-slate-800.pt-1 = "Taxa de acerto"
                td.text-2xl.font-bold.text-blue-500.text-right
                  = "#{trace.profit_trade(:slaves).round(2)} %"
                  .text-sm.text-slate-800.pt-1 = "Taxa de acerto"
              tr
                td.text-2xl.font-bold.text-blue-500
                  = "#{trace.loss_trade(:masters).round(2)} %"
                  .text-sm.text-slate-800.pt-1 = "Taxa de perda"
                td.text-2xl.font-bold.text-blue-500.text-right
                  = "#{trace.loss_trade(:slaves).round(2)} %"
                  .text-sm.text-slate-800.pt-1 = "Taxa de perda"
              tr
                td.text-2xl.font-bold.text-blue-500
                  = "#{trace.pay_off(:masters).round(2)}"
                  .text-sm.text-slate-800.pt-1 = "Payoff"
                td.text-2xl.font-bold.text-blue-500.text-right
                  = "#{trace.pay_off(:slaves).round(2)}"
                  .text-sm.text-slate-800.pt-1 = "Payoff"
              tr
                td.text-2xl.font-bold.text-blue-500
                  = "#{trace.profit_factor(:masters).round(2)}"
                  .text-sm.text-slate-800.pt-1 = "Fator de Lucro"
                td.text-2xl.font-bold.text-blue-500.text-right
                  = "#{trace.profit_factor(:slaves).round(2)}"
                  .text-sm.text-slate-800.pt-1 = "Fator de Lucro"
              tr
                td.text-2xl.font-bold.text-blue-500
                  = "#{trace.drawdown(:masters).round(2)}"
                  .text-sm.text-slate-800.pt-1 = "Drawdown"
                td.text-2xl.font-bold.text-blue-500.text-right
                  = "#{trace.drawdown(:slaves).round(2)}"
                  .text-sm.text-slate-800.pt-1 = "Drawdown"
              tr
                td.py-2
                  .font-medium.text-left.text-slate-800 
                    | Compra
                    '
                    = trace.masters.closed.buy.count
                td.py-2
                  .font-medium.text-right.text-slate-800 
                    | Compra
                    '
                    = trace.slaves.closed.buy.count
              /! Row
              tr
                td.py-2
                  .font-medium.text-left.text-slate-800 
                    | Venda
                    '
                    = trace.masters.closed.sell.count
                td.py-2
                  .font-medium.text-right.text-slate-800 
                    | Venda
                    '
                    = trace.slaves.closed.sell.count
              tr
                td.py-2
                  .font-medium.text-left.text-slate-800 
                    | Gain
                    '
                    = trace.masters.closed.gain.count
                td.py-2
                  .font-medium.text-right.text-slate-800 
                    | Gain
                    '
                    = trace.slaves.closed.gain.count
              tr
                td.py-2
                  .font-medium.text-left.text-slate-800 
                    | Loss
                    '
                    = trace.masters.closed.loss.count

                td.py-2
                  .font-medium.text-right.text-slate-800 
                    | Loss
                    '
                    = trace.slaves.closed.loss.count

                    
      .px-2.py-2
      /   .flex.items-center
      /     /! Red dot
      /     .relative.flex.items-center.justify-center.w-4.h-4.rounded-full.bg-rose-100.mr-3 aria-hidden="true" 
      /       .absolute.rounded-full.bg-rose-500 class=("w-1.5 h-1.5") 
      /     /! Vistors number
      /     div
      /       .text-2xl.font-bold.text-blue-500 = "R$ #{trace.orders.closed.map.sum(&:profit_copy)} - #{number_with_precision((trace.orders.closed.map.sum(&:profit_slave).to_f / trace.accounts.count), precision: 2)} = #{number_with_precision((trace.orders.closed.map.sum(&:profit_copy).to_f - trace.orders.closed.map.sum(&:profit_slave).to_f / trace.accounts.count), precision: 2) } "
      /       .text-sm.text-slate-800.pt-1 = "Diferança aprox. do profit do Copy p/ os Slaves."

      / /! Card footer
      / .text-right.px-5.pb-4
      /   a.text-sm.font-medium.text-indigo-500.hover:text-indigo-600 href="#0"  Real-Time Report -&gt;

