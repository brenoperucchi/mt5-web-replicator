# OS/editor noise
.DS_Store
*.sublime-workspace
/.history

# Ruby/Bundler
/.bundle
/vendor/bundle
*.rbc
.rbenv-gemsets
.rspec
.rvmrc

# Rails runtime
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/storage/*
!/storage/.keep
/public/system
/coverage/
/spec/tmp
capybara-*.html
rerun.txt
pickle-email-*.html
.byebug_history
*.orig

# Databases and local generated data
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-[0-9]*
database.json
lib/signal/database.json
lib/signal/images/data/output.tiff

# JavaScript build output
/node_modules
/public/packs
/public/packs-test
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# Rails credentials and local secrets
/.env
/config/master.key
/config/credentials/*.key
config/initializers/secret_token.rb

# Project-specific generated files
lib/signal/__pycache__/
lib/signal/lib/__pycache__/
*.pyc
lib/telegram/tdlib/libtdjson.so
public/mntpoint/signal_copy_trasmit.txt
public/mntpoint/signal_copy_trasmit.txt.tmp
